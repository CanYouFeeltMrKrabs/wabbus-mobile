{
  "name": "wabbus-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "unset CI && expo start",
    "dev": "unset CI && expo start --dev-client",
    "android": "unset CI && expo run:android",
    "ios": "unset CI && expo run:ios",
    "rebuild:ios": "expo prebuild --clean && cd ios && pod install && cd .. && SENTRY_DISABLE_AUTO_UPLOAD=true xcodebuild -workspace ios/Wabbus.xcworkspace -scheme Wabbus -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 17 Pro' -derivedDataPath ios/build build CODE_SIGNING_ALLOWED=NO && xcrun simctl install booted ios/build/Build/Products/Debug-iphonesimulator/Wabbus.app",
    "web": "unset CI && expo start --web",
    "lint": "eslint .",
    "check:queries": "bash scripts/check-query-imports.sh"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@stripe/stripe-react-native": "^0.63.0",
    "@tanstack/react-query": "^5.96.2",
    "expo": "~55.0.14",
    "expo-apple-authentication": "^55.0.13",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.12",
    "expo-localization": "~55.0.13",
    "expo-notifications": "~55.0.18",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "^55.0.20",
    "expo-video": "~55.0.15",
    "i18next": "^26.0.4",
    "react": "19.2.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "react-native-worklets-core": "^1.6.3",
    "socket.io-client": "^4.8.3",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo-dev-client": "55.0.24",
    "typescript": "~5.9.2"
  },
  "private": true
}
