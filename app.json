{
  "expo": {
    "name": "Wabbus",
    "slug": "wabbus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wabbus",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d4ecf"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wabbus.mobile",
      "associatedDomains": [
        "applinks:wabbus.com",
        "applinks:www.wabbus.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2d4ecf",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.wabbus.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/product" },
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/orders" },
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/category" },
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/vendors" },
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/support" },
            { "scheme": "https", "host": "wabbus.com", "pathPrefix": "/account" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/product" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/orders" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/category" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/vendors" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/support" },
            { "scheme": "https", "host": "www.wabbus.com", "pathPrefix": "/account" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2d4ecf"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.wabbus.mobile",
          "enableGooglePay": true
        }
      ]
    ]
  }
}
